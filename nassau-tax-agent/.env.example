LANGSMITH_API_KEY="YOUR_LANGSMITH_API_KEY"
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_PROJECT="Nassau Tax Agent"

# LLM Provider API Key (choose one)
GOOGLE_API_KEY="YOUR_GOOGLE_API_KEY"
